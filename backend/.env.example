# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/bike-ride-booking
# For MongoDB Atlas (Production):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/bike-ride-booking?retryWrites=true&w=majority

# JWT Secret (Change this to a random secure string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=5000
NODE_ENV=development

# Email Configuration (Gmail Example)
# Generate App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: Email Service Provider
# Options: gmail, outlook, yahoo, etc.
EMAIL_SERVICE=gmail
